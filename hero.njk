<section id="{{ componentId }}" class="component py-24">
  <div class="container mx-auto px-6 text-center">

    {% if shop.image_url %}
      <img
        src="{{ shop.image_url }}"
        alt="{{ shop.name }}"
        class="mx-auto mb-8 max-h-40"
      >
    {% endif %}

    <h1 class="text-5xl font-extrabold text-white mb-6">
      HAZE <span class="text-accent-500">Reselling</span>
    </h1>

    <p class="text-xl text-white/70 max-w-2xl mx-auto mb-10">
      Premium Accounts • Instant Delivery • Trusted Service
    </p>

    <div class="flex justify-center gap-4 flex-wrap">
      <a href="/products" class="px-8 py-4 bg-accent-500 text-white font-bold rounded-lg hover:scale-105 transition">
        Shop Now
      </a>

      <a href="/feedback" class="px-8 py-4 border border-accent-500 text-accent-500 font-bold rounded-lg hover:bg-accent-500 hover:text-white transition">
        Reviews
      </a>
    </div>

  </div>
</section>
