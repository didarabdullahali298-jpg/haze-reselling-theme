<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">
  <div class="py-6 lg:py-8">
    {% if properties.title %}
      <div class="flex items-center justify-center mb-4 md:mb-6 lg:mb-8">
        <div class="inline-block">
          <h1 class="text-t-primary text-2xl text-center font-bold md:text-3xl lg:text-4xl">
            {{ properties.title | renderString }}
          </h1>
          <hr class="w-full border-accent-500 mt-1 md:border-2 md:mt-1.5 lg:mt-2 mx-auto">
        </div>
      </div>
    {% endif %}

    <div class="flex flex-wrap gap-4 w-full {{ 'justify-center' if properties.centered }}">
      {% for feature in properties.features %}
        <div class="w-full sm:w-[calc((100%-1rem)/2)] lg:w-[calc((100%-2rem)/3)] 2xl:w-[calc((100%-3rem)/4)]">
          <div class="text-center bg-card/75 border border-white/5 p-4 lg:p-6">
            <i class="mb-2 text-accent-500 text-xl mb:mb-3 md:text-2xl lg:mb-4 lg:text-3xl {{ feature.icon }}"></i>
            <h4 class="mb-1 text-base text-t-primary font-semibold uppercase mb:mb-1.5 lg:text-lg lg:mb-2">
              {{ feature.title | renderString }}
            </h4>
            <p class="text-xs font-normal text-t-primary/80 lg:text-sm">
              <span class="whitespace-pre-line">{{ feature.description | renderString }}</span>
            </p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>