<section id="{{ componentId }}" class="component" data-component-id="{{ componentId }}">
  <div class="py-6 lg:py-8">
    {% if properties.title %}
      <div class="flex items-center justify-center mb-4 md:mb-6 lg:mb-8">
        <div class="inline-block">
          <h2 class="text-t-primary text-2xl text-center font-bold md:text-3xl lg:text-4xl">
            {{ properties.title | renderString }}
          </h2>
          <hr class="w-full border-accent-500 mt-1 md:border-2 md:mt-1.5 lg:mt-2 mx-auto">
        </div>
      </div>
    {% endif %}

    <div class="flex flex-wrap gap-4 w-full {{ 'justify-center' if properties.centered }}">
      {% for category in categories %}
        <div class="w-full sm:w-[calc((100%-1rem)/2)] lg:w-[calc((100%-2rem)/3)] 2xl:w-[calc((100%-3rem)/4)]">
          <a
            class="block bg-card/75 border border-white/5 hover:border-accent-500/50 transition-colors duration-200 text-t-primary"
            href="{{ category.url }}"
          >
            <div class="border-b border-white/5">
              {% if category.image_url %}
                <img src="{{ category.image_url }}" class="w-full aspect-video object-cover" loading="lazy" />
              {% else %}
                <div class="flex justify-center items-center text-accent-400/50 aspect-video">
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-24" viewBox="0 0 256 256">
                    <path fill="currentColor" d="m222.72 67.91l-88-48.18a13.9 13.9 0 0 0-13.44 0l-88 48.18A14 14 0 0 0 26 80.18v95.64a14 14 0 0 0 7.28 12.27l88 48.18a13.92 13.92 0 0 0 13.44 0l88-48.18a14 14 0 0 0 7.28-12.27V80.18a14 14 0 0 0-7.28-12.27ZM127 30.25a2 2 0 0 1 1.92 0L212.51 76l-33.94 18.57l-84.52-46.26ZM122 223l-83-45.43a2 2 0 0 1-1-1.75V86.66l84 46ZM43.49 76l38.07-20.85l84.51 46.26L128 122.24ZM218 175.82a2 2 0 0 1-1 1.75L134 223v-90.36l36-19.71V152a6 6 0 0 0 12 0v-45.63l36-19.71Z"/>
                  </svg>
                </div>
              {% endif %}
            </div>
            <div class="p-4">
              <h3 class="text-base font-semibold uppercase truncate mb-1">
                {{ category.name }}
              </h3>
              <p class="text-sm text-t-primary/60 line-clamp-2 mb-3">
                {{ category.description }}
              </p>
              <span class="text-xs text-accent-500 font-semibold uppercase">View Products →</span>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
